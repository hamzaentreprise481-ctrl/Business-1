# Copiez ce fichier en ".env" en local, et configurez les mêmes variables
# dans Vercel (Project Settings > Environment Variables) pour la prod.
# NE JAMAIS committer le fichier ".env" (déjà exclu via .gitignore)

# Clé secrète Stripe (trouvable sur https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_votre_cle_ici

# Identifiants Firebase (récupérés depuis la console Firebase > Paramètres du projet > Comptes de service)
# Astuce : sur Vercel, collez le JSON complet du fichier de clé de service ici
# (sur une seule ligne) dans une variable nommée FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
